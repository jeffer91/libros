# =========================================================
# Nombre completo: .gitignore
# Ruta o ubicación: /.gitignore
#
# Función:
# Evitar que se suban a GitHub archivos pesados, temporales,
# privados o generados automáticamente.
#
# Con qué se conecta:
# - Git
# - GitHub
# - Electron Builder
# - Node.js
#
# Para qué sirve:
# Mantiene limpio el repositorio jeffer91/eventos.
# =========================================================

# Dependencias
node_modules/

# Compilados e instaladores generados
dist/
out/
release/
build/
*.AppImage
*.dmg
*.exe
*.msi
*.zip
*.7z
*.blockmap

# Archivos de configuración local o privados
.env
.env.local
.env.production
.env.development
*.pem
*.key
*.p12
*.cert

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Cachés
.cache/
.parcel-cache/
.eslintcache
.npm/
.yarn/
.pnpm-store/

# Sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# Visual Studio Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains
.idea/

# Archivos temporales
tmp/
temp/
*.tmp
*.bak
*.old
*.swp

# Archivos de prueba local de auto-update
dev-app-update.yml

# Respaldos locales de la app
backups/
backup/
respaldo/
respaldos/

# Datos locales exportados por pruebas
*.local.json
*.backup.json
*.sqlite
*.sqlite3